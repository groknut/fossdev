
# 7. Прописать команду запуска в Makefile,
# сделать определения переменной окружения так чтобы oreder service могу найти product даже если он запущен не на 8001 порте

.DEFAULT_GOAL := help

help:
	@echo "This makefile for services up"

PRODUCT_PORT ?= 8001
ORDER_PORT ?= 8002
HOST ?= 127.0.0.1

PRODUCT_SERVICE_URL ?= http://${HOST}:${PRODUCT_PORT}

run-product:
	cd product_service && poetry run uvicorn src.app.main:app --host $(HOST) --port $(PRODUCT_PORT)

run-order:
	cd order_service && export PRODUCT_SERVICE_URL && poetry run uvicorn src.app.main:app --host $(HOST) --port $(ORDER_PORT)

run:
	make -j2 run-order run-product
